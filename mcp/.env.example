# Copy this file to `.env` and fill in your key. The `.env` file is gitignored.
# Only `npm run eval` reads these; the MCP server itself takes no env from here.

# REQUIRED for `npm run eval`. Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OPTIONAL. Override the backend to point at a local stack instead of Heroku.
# LICENSE_SERVICE_BASE_URL=http://localhost:3000

# OPTIONAL. Hard cap on total Anthropic spend per eval invocation. Default 5.00.
# COST_CAP_USD=5.00

# OPTIONAL. Number of samples per case for the pass-rate calculation. Default 5.
# SAMPLES_PER_CASE=5

# OPTIONAL. Substring-match against case names. Useful when iterating on one case.
# CASE_FILTER=duplicate
