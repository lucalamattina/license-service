NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# Postgres - matches docker-compose.yml defaults. Used from Phase 1 onward.
DATABASE_URL=postgres://license_service:license_service@localhost:5433/license_service
TEST_DATABASE_URL=postgres://license_service:license_service@localhost:5433/license_service_test

# Redis - matches docker-compose.yml (port 6380 to avoid clashing with any host redis).
REDIS_URL=redis://localhost:6380
TEST_REDIS_URL=redis://localhost:6380

# CORS allowlist - comma-separated. Entries may contain `*` as a wildcard for one
# subdomain label (does NOT cross dots), e.g. `https://*.vercel.app` matches
# `foo.vercel.app` but not `foo.bar.vercel.app`. If unset, defaults to
# http://localhost:5173 (the companion dashboard's Vite dev server).
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://license-service-dashboard.vercel.app,https://license-service-dashboard-*.vercel.app
